{
  "openapi": "3.1.1",
  "info": {
    "title": "ServiceC - Orders API",
    "description": "API for managing orders",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5003/"
    }
  ],
  "paths": {
    "/api/orders": {
      "get": {
        "tags": [
          "ServiceC"
        ],
        "operationId": "GetOrders",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/orders/{id}": {
      "get": {
        "tags": [
          "ServiceC"
        ],
        "operationId": "GetOrderById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "ServiceC"
        ],
        "operationId": "DeleteOrder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "ServiceC"
    }
  ]
}